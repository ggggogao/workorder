# Railway 自动注入（添加 MySQL 数据库后自动有这个变量）
DATABASE_URL=mysql://user:pass@host:3306/dbname

PORT=3001
NODE_ENV=production
JWT_SECRET=请替换为32位随机字符串

# Resend 邮件（免费，注册 resend.com 获取）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAIL_FROM=gaoxian@yuanxinkeji.com
MAIL_FROM_NAME=健康服务工单系统

# 接收通知的邮箱（逗号分隔）
NOTIFY_EMAILS=gaoxian@yuanxinkeji.com

# 企业微信群机器人（可选）
WECOM_WEBHOOK_URL=

# 外部系统对接密钥（可选）
EXTERNAL_API_KEY=your_key_here

# 定时触达（工作日08:30）
NOTIFY_CRON=30 8 * * 1-5
